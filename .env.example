# ============================================================
# OPERON INTELLIGENCE PLATFORM — Environment Configuration
# Copie este arquivo para .env e preencha os valores reais
# NUNCA commitar o .env com valores reais
# ============================================================

# ── APP ──────────────────────────────────────────────────────
APP_NAME="Operon Intelligence"
APP_ENV=local
APP_DEBUG=true
APP_URL=http://localhost:8000
APP_SECRET=change-this-to-a-random-32-char-string
APP_ENCRYPTION_KEY=change-this-to-a-random-64-hex-string

# ── DATABASE ─────────────────────────────────────────────────
# Para desenvolvimento: sqlite
# Para produção: pgsql
DB_CONNECTION=sqlite
DB_DATABASE=database/operon.db

# PostgreSQL (produção)
# DB_CONNECTION=pgsql
# DB_HOST=127.0.0.1
# DB_PORT=5432
# DB_DATABASE=operon
# DB_USERNAME=operon
# DB_PASSWORD=secret

# ── AI PROVIDERS ─────────────────────────────────────────────
# Provider ativo: gemini | openai | grok
OPERON_PROVIDER=gemini
OPERON_MODEL=gemini-2.0-flash

# Google Gemini
GEMINI_API_KEY=

# OpenAI (fallback)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o

# Grok / xAI (alternativo)
GROK_API_KEY=
GROK_MODEL=grok-2

# ── EXTERNAL APIs ────────────────────────────────────────────
# Google PageSpeed Insights (opcional — enriquecimento de leads)
PAGESPEED_API_KEY=

# Google Places API (opcional — Atlas de Vendas)
GOOGLE_PLACES_API_KEY=

# ── CACHE / QUEUE ────────────────────────────────────────────
CACHE_DRIVER=file
QUEUE_DRIVER=database

# Redis (opcional — para produção)
# REDIS_HOST=127.0.0.1
# REDIS_PORT=6379
# REDIS_PASSWORD=

# ── OPERON TOKEN ECONOMY ─────────────────────────────────────
TOKEN_TIER_STARTER=100
TOKEN_TIER_PRO=500
TOKEN_TIER_ELITE=2000
TOKEN_TIMEZONE=America/Sao_Paulo

# ── MAIL (para notificações futuras) ─────────────────────────
MAIL_MAILER=smtp
MAIL_HOST=mailpit
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
