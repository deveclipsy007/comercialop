{
  "manifest_version": 3,
  "name": "Operon Capture",
  "version": "1.0.0",
  "description": "Capture leads diretamente da navegação para a plataforma Operon Intelligence.",
  "permissions": [
    "activeTab",
    "storage",
    "tabs"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon-16.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },
  "background": {
    "service_worker": "background/service-worker.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": [
        "https://www.google.com/maps/*",
        "https://www.google.com.br/maps/*",
        "https://maps.google.com/*"
      ],
      "js": ["content/google-maps.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://www.linkedin.com/*"],
      "js": ["content/linkedin.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["<all_urls>"],
      "js": ["content/generic.js"],
      "run_at": "document_idle",
      "exclude_matches": [
        "https://www.google.com/maps/*",
        "https://www.google.com.br/maps/*",
        "https://maps.google.com/*",
        "https://www.linkedin.com/*"
      ]
    }
  ],
  "icons": {
    "16": "icons/icon-16.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  }
}
